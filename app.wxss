page {
  --primary-color: #2E7D32;
  --secondary-color: #4CAF50;
  --accent-color: #81C784;
  --bg-color: #E8F5E9;
  --card-bg: #FFFFFF;
  --text-dark: #1B5E20;
  --text-light: #558B2F;
  --border-color: #C8E6C9;

  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-dark);
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  text-align: center;
  margin: 40rpx 24rpx 30rpx;
  position: relative;
}

.section-title::after {
  content: '';
  display: block;
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  margin: 16rpx auto 0;
  border-radius: 2rpx;
}

.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary-color), var(--secondary-color));
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.card-content {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.8;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  border-radius: 44rpx;
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.25);
}

.tag {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  color: var(--primary-color);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(46, 125, 50, 0.15);
}

.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: var(--card-bg);
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.05);
  transition: all 0.3s ease;
}

.list-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.03), rgba(76, 175, 80, 0.06));
}

.list-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 44rpx;
  margin-right: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.list-content {
  flex: 1;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.list-desc {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 24rpx;
}

.grid-item {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.05);
  transition: all 0.3s ease;
}

.grid-item:active {
  transform: scale(0.98);
}

.grid-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 24rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.2);
}

.grid-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.grid-desc {
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.fade-in {
  animation: fadeIn 0.6s ease-out;
}

.slide-up {
  animation: slideUp 0.6s ease-out;
}

.scale-in {
  animation: scaleIn 0.5s ease-out;
}

swiper {
  position: relative;
}

swiper .wx-swiper-dot,
swiper .uni-swiper-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

swiper .wx-swiper-dot-active,
swiper .uni-swiper-dot-active {
  width: 48rpx;
  height: 14rpx;
  border-radius: 7rpx;
  background: white;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 8rpx rgba(255, 255, 255, 0.4);
}

swiper .wx-swiper-dot:only-child,
swiper .uni-swiper-dot:only-child {
  display: flex;
  justify-content: center;
}

@media (max-width: 375px) {
  .grid {
    grid-template-columns: 1fr;
  }

  .section-title {
    font-size: 32rpx;
    margin: 32rpx 20rpx 24rpx;
  }

  .card {
    padding: 28rpx;
    margin: 0 20rpx 20rpx;
  }

  .list-item {
    padding: 24rpx;
    margin: 0 20rpx 16rpx;
  }
}