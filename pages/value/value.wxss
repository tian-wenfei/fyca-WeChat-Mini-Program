.container {
  padding-bottom: 40rpx;
}

/* ===== Hero Section ===== */
.hero-section {
  position: relative;
  padding: 60rpx 40rpx;
  margin: 24rpx;
  background: linear-gradient(135deg, #1a5c2a 0%, #2d8a4e 40%, #4caf50 100%);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(26, 92, 42, 0.3);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.95);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.15);
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.8;
  text-align: justify;
  letter-spacing: 0.5rpx;
}

/* ===== Section ===== */
.section {
  margin: 40rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon-box {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--primary-color);
  letter-spacing: 1rpx;
}

/* ===== Tech Value Card ===== */
.tech-value-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.tech-value-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.tech-value-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.tech-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
}

.tech-info {
  flex: 1;
}

.tech-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.tech-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.tech-value-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tech-tag {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  color: var(--primary-color);
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(46, 125, 50, 0.15);
}

/* ===== Income Card ===== */
.income-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.income-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.income-stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid rgba(46, 125, 50, 0.08);
}

.income-stat {
  text-align: center;
}

.income-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.income-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  font-weight: 500;
}

.income-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.7;
  text-align: center;
}

/* ===== Upgrade Card ===== */
.upgrade-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.upgrade-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.upgrade-items {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.upgrade-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.04), rgba(76, 175, 80, 0.08));
  border-radius: 18rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.upgrade-item:active {
  transform: translateX(6rpx);
  box-shadow: 0 4rpx 20rpx rgba(46, 125, 50, 0.12);
}

.upgrade-icon {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.2);
}

.upgrade-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 6rpx;
}

.upgrade-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}

/* ===== Responsibility Grid ===== */
.responsibility-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.responsibility-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 28rpx 20rpx;
  background: var(--card-bg);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.responsibility-item:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 20rpx rgba(46, 125, 50, 0.12);
}

.responsibility-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.12), rgba(76, 175, 80, 0.18));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 14rpx;
}

.responsibility-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 10rpx;
}

.responsibility-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.6;
}

/* ===== Responsive ===== */
@media (max-width: 375px) {
  .hero-section {
    padding: 48rpx 28rpx;
    margin: 20rpx;
  }

  .hero-title {
    font-size: 48rpx;
  }

  .income-stat-row {
    flex-direction: column;
    gap: 20rpx;
  }

  .responsibility-grid {
    grid-template-columns: 1fr;
  }
}
