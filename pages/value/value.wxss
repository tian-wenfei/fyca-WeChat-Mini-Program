.container {
  padding-bottom: 40rpx;
}

/* 顶部标语 */
.value-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 8rpx;
}

/* 核心价值卡片 */
.value-cards {
  margin: 20rpx 0;
}

.value-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
  border-left: 8rpx solid var(--primary-color);
}

.value-quality {
  border-left-color: #D2691E;
}

.value-innovation {
  border-left-color: #CD853F;
}

.value-responsibility {
  border-left-color: #8B4513;
}

.card-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.value-points {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.point {
  background: rgba(46, 125, 50, 0.1);
  color: var(--primary-color);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 品质承诺 */
.promise-list {
  margin: 20rpx 0;
}

.promise-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.promise-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.promise-content {
  flex: 1;
}

.promise-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.promise-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
}

/* 创新成果统计 */
.innovation-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin: 20rpx 0;
}

.inno-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.inno-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.inno-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
}

/* 社会责任网格 */
.social-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 20rpx 0;
}

.social-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.social-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.social-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.social-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}

/* 客户评价 */
.review-list {
  margin: 20rpx 0;
}

.review-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.review-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.review-info {
  flex: 1;
}

.review-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.review-stars {
  display: flex;
}

.star {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.review-content {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.8;
  font-style: italic;
}
