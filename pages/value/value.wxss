.container {
  padding-bottom: 60rpx;
}

.value-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 32rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.value-header::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 60%;
  height: 150%;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 60%);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 8rpx;
  position: relative;
  z-index: 1;
}

.value-cards {
  margin: 0 24rpx 32rpx;
}

.value-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.value-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
}

.value-quality::before {
  background: linear-gradient(180deg, #D2691E, #CD853F);
}

.value-innovation::before {
  background: linear-gradient(180deg, var(--primary-color), var(--secondary-color));
}

.value-responsibility::before {
  background: linear-gradient(180deg, #8B4513, #A0522D);
}

.value-card:active {
  transform: scale(0.99);
}

.card-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.value-points {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.point {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  color: var(--primary-color);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(46, 125, 50, 0.15);
}

.promise-list {
  margin: 0 24rpx 32rpx;
}

.promise-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.promise-item:active {
  transform: scale(0.98);
}

.promise-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.promise-content {
  flex: 1;
}

.promise-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.promise-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
}

.innovation-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 24rpx 32rpx;
}

.inno-item {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  position: relative;
  overflow: hidden;
}

.inno-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
}

.inno-number {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.inno-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

.social-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 24rpx;
}

.social-item {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.05);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.social-item:active {
  transform: scale(0.98);
}

.social-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin: 0 auto 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.social-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.social-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}

.review-list {
  margin: 0 24rpx;
}

.review-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.review-avatar {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.2);
}

.review-info {
  flex: 1;
}

.review-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.review-stars {
  display: flex;
  gap: 6rpx;
}

.star {
  font-size: 26rpx;
  color: #FFD700;
}

.review-content {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.8;
  font-style: italic;
}

.footer {
  text-align: center;
  padding: 48rpx 0 24rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 22rpx;
  color: var(--text-light);
  opacity: 0.7;
}

@media (max-width: 375px) {
  .social-grid {
    grid-template-columns: 1fr;
  }

  .innovation-stats {
    grid-template-columns: 1fr;
  }

  .header-title {
    font-size: 42rpx;
  }
}