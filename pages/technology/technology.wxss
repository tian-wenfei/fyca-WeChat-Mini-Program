.container {
  padding-bottom: 60rpx;
}

.tech-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 32rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.tech-header::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 60%;
  height: 150%;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 60%);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 6rpx;
  position: relative;
  z-index: 1;
}

.tech-list {
  margin: 0 24rpx 32rpx;
}

.tech-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.tech-item:active {
  transform: scale(0.98);
}

.tech-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.tech-info {
  flex: 1;
}

.tech-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.tech-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
}

.process-flow {
  margin: 0 24rpx 32rpx;
}

.process-item {
  display: flex;
  align-items: flex-start;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.process-item:active {
  transform: scale(0.98);
}

.process-step {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.process-content {
  flex: 1;
  padding-top: 4rpx;
}

.process-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 12rpx;
}

.process-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
}

.product-series {
  margin: 0 24rpx 32rpx;
}

.series-card {
  background: linear-gradient(135deg, var(--card-bg) 0%, rgba(129, 199, 132, 0.1) 100%);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.series-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.series-emoji {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.series-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.series-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 24rpx;
  line-height: 1.7;
}

.series-features {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.feature-tag {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  color: var(--primary-color);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(46, 125, 50, 0.15);
}

.quality-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 24rpx;
}

.quality-item {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.05);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.quality-item:active {
  transform: scale(0.98);
}

.quality-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin: 0 auto 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.quality-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.quality-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.4;
}

.patent-list {
  margin: 0 24rpx;
}

.patent-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.05);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.patent-item:active {
  transform: scale(0.98);
}

.patent-number {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  margin-right: 24rpx;
  font-family: monospace;
  font-weight: 600;
}

.patent-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-dark);
  font-weight: 500;
}

.footer {
  text-align: center;
  padding: 48rpx 0 24rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 22rpx;
  color: var(--text-light);
  opacity: 0.7;
}

@media (max-width: 375px) {
  .quality-grid {
    grid-template-columns: 1fr;
  }

  .tech-icon {
    width: 88rpx;
    height: 88rpx;
  }

  .process-step {
    width: 76rpx;
    height: 76rpx;
  }
}