.container {
  padding-bottom: 40rpx;
}

/* 顶部标题区 */
.tech-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 技术列表 */
.tech-list {
  margin: 20rpx 0;
}

.tech-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.tech-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tech-info {
  flex: 1;
}

.tech-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.tech-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
}

/* 制茶工艺流程 */
.process-flow {
  margin: 20rpx 0;
}

.process-item {
  display: flex;
  align-items: flex-start;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.process-step {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.process-content {
  flex: 1;
}

.process-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 12rpx;
}

.process-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
}

/* 产品系列 */
.product-series {
  margin: 20rpx 0;
}

.series-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.series-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.series-emoji {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.series-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.series-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.series-features {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.feature-tag {
  background: rgba(46, 125, 50, 0.1);
  color: var(--primary-color);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 质量保障 */
.quality-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 20rpx 0;
}

.quality-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.quality-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.quality-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.quality-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

/* 专利列表 */
.patent-list {
  margin: 20rpx 0;
}

.patent-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.patent-number {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 20rpx;
  font-family: monospace;
}

.patent-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-dark);
  font-weight: 500;
}
