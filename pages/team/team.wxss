.container {
  padding-bottom: 40rpx;
}

/* 顶部标题 */
.team-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 团队列表 */
.team-list {
  margin: 20rpx 0;
}

.team-card {
  display: flex;
  align-items: flex-start;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.team-avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.team-info {
  flex: 1;
}

.team-header-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.team-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-right: 16rpx;
}

.team-position {
  font-size: 24rpx;
  color: var(--primary-color);
  background: rgba(46, 125, 50, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.team-desc {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
}

/* 组织架构网格 */
.dept-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 20rpx 0;
}

.dept-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.dept-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.dept-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.dept-count {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
}

/* 专家顾问 */
.advisor-list {
  margin: 20rpx 0;
}

.advisor-card {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.advisor-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.advisor-info {
  flex: 1;
}

.advisor-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.advisor-title {
  display: block;
  font-size: 26rpx;
  color: var(--primary-color);
  margin-bottom: 4rpx;
}

.advisor-field {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

/* 团队文化 */
.culture-card {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 20rpx 0;
}

.culture-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.culture-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.culture-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.culture-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

/* 加入我们 */
.join-section {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 16rpx;
  padding: 50rpx 40rpx;
  margin: 40rpx 0 20rpx;
  text-align: center;
}

.join-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.join-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 30rpx;
}

.join-btn {
  background: white;
  color: var(--primary-color);
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.join-btn::after {
  border: none;
}
