.container {
  padding-bottom: 60rpx;
}

.team-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 32rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.team-header::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 60%;
  height: 150%;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 60%);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.team-list {
  margin: 0 24rpx 32rpx;
}

.team-card {
  display: flex;
  align-items: flex-start;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.team-card:active {
  transform: scale(0.98);
}

.team-avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.team-info {
  flex: 1;
}

.team-header-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.team-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-dark);
}

.team-position {
  font-size: 24rpx;
  color: var(--primary-color);
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.team-desc {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
}

.advisor-list {
  margin: 0 24rpx 32rpx;
}

.advisor-card {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.advisor-card:active {
  transform: scale(0.98);
}

.advisor-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.advisor-info {
  flex: 1;
}

.advisor-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.advisor-title {
  display: block;
  font-size: 26rpx;
  color: var(--primary-color);
  margin-bottom: 4rpx;
  font-weight: 500;
}

.advisor-field {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.culture-card {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 24rpx 32rpx;
}

.culture-item {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.05);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.culture-item:active {
  transform: scale(0.98);
}

.culture-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin: 0 auto 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.2);
}

.culture-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.culture-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.4;
}

.contact-cards {
  margin: 0 24rpx 32rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.contact-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.contact-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.card-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.card-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 10rpx;
  font-weight: 500;
}

.card-value {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  word-break: break-all;
}

.social-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin: 0 24rpx 32rpx;
}

.social-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.social-item:active {
  transform: scale(0.98);
}

.social-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.social-name {
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

.join-section {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 24rpx;
  padding: 56rpx 40rpx;
  margin: 0 24rpx 32rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.join-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 80%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
}

.join-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.join-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.join-btn {
  background: white;
  color: var(--primary-color);
  border-radius: 44rpx;
  padding: 24rpx 64rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  position: relative;
  z-index: 1;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.join-btn::after {
  border: none;
}

.join-btn:active {
  transform: scale(0.98);
}

.footer {
  text-align: center;
  padding: 48rpx 0 24rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 22rpx;
  color: var(--text-light);
  opacity: 0.7;
}

@media (max-width: 375px) {

  .culture-card {
    grid-template-columns: 1fr;
  }

  .contact-cards {
    grid-template-columns: 1fr;
  }

  .social-section {
    grid-template-columns: repeat(2, 1fr);
  }

  .header-title {
    font-size: 42rpx;
  }

  .team-card {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .team-avatar {
    margin-right: 0;
    margin-bottom: 20rpx;
  }

  .team-header-info {
    justify-content: center;
  }
}