<view class="container">
  <view class="team-header">
    <text class="header-title">团队与联系</text>
    <text class="header-subtitle">专业团队 · 匠心品质</text>
  </view>

  <view class="section-title">核心团队</view>
  <view class="team-list">
    <view class="team-card" wx:for="{{coreTeam}}" wx:key="id">
      <view class="team-avatar">{{item.avatar}}</view>
      <view class="team-info">
        <view class="team-header-info">
          <text class="team-name">{{item.name}}</text>
          <text class="team-position">{{item.position}}</text>
        </view>
        <text class="team-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="section-title">专家顾问</view>
  <view class="advisor-list">
    <view class="advisor-card" wx:for="{{advisors}}" wx:key="id">
      <view class="advisor-avatar">{{item.avatar}}</view>
      <view class="advisor-info">
        <text class="advisor-name">{{item.name}}</text>
        <text class="advisor-title">{{item.title}}</text>
        <text class="advisor-field">{{item.field}}</text>
      </view>
    </view>
  </view>

  <view class="section-title">团队文化</view>
  <view class="culture-card">
    <view class="culture-item">
      <view class="culture-icon">🎯</view>
      <text class="culture-title">专业专注</text>
      <text class="culture-desc">专注茯茶产业，追求极致品质</text>
    </view>
    <view class="culture-item">
      <view class="culture-icon">🤝</view>
      <text class="culture-title">协作共赢</text>
      <text class="culture-desc">团队协作，共同成长</text>
    </view>
    <view class="culture-item">
      <view class="culture-icon">💡</view>
      <text class="culture-title">持续创新</text>
      <text class="culture-desc">勇于创新，引领行业</text>
    </view>
    <view class="culture-item">
      <view class="culture-icon">❤️</view>
      <text class="culture-title">回馈社会</text>
      <text class="culture-desc">热心公益，责任担当</text>
    </view>
  </view>

  <view class="section-title">联系方式</view>
  <view class="contact-cards">
    <view class="contact-card" bindtap="copyEmail">
      <view class="card-icon">✉️</view>
      <text class="card-label">电子邮箱</text>
      <text class="card-value">948979226@qq.com</text>
    </view>
    <view class="contact-card" bindtap="makePhoneCall">
      <view class="card-icon">📞</view>
      <text class="card-label">联系电话</text>
      <text class="card-value">+86 15091730188</text>
    </view>
    <view class="contact-card">
      <view class="card-icon">📍</view>
      <text class="card-label">公司地址</text>
      <text class="card-value">陕西省西安市长安区子午大道中段39号</text>
    </view>
  </view>

  <view class="section-title">关注我们</view>
  <view class="social-section">
    <view class="social-item" bindtap="openWechat">
      <view class="social-icon">📱</view>
      <text class="social-name">微信</text>
    </view>
    <view class="social-item" bindtap="openDouyin">
      <view class="social-icon">📺</view>
      <text class="social-name">抖音</text>
    </view>
    <view class="social-item" bindtap="openWebsite">
      <view class="social-icon">🌐</view>
      <text class="social-name">官网</text>
    </view>
    <view class="social-item" bindtap="openWeibo">
      <view class="social-icon">📝</view>
      <text class="social-name">微博</text>
    </view>
  </view>

  <view class="join-section">
    <text class="join-title">加入我们</text>
    <text class="join-desc">诚邀有志之士加入茯忆长安大家庭</text>
    <button class="join-btn" bindtap="makePhoneCall">立即联系</button>
  </view>

  <view class="footer">
    <text class="footer-text">© 2026 茯忆长安 版权所有</text>
    <text class="footer-icp">陕ICP备2026007411号</text>
  </view>
</view>