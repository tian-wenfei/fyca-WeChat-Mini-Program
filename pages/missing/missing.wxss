.container {
  padding-bottom: 60rpx;
}

.missing-header {
  background: linear-gradient(135deg, #8B4513, #A0522D);
  margin: -20rpx -20rpx 32rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.missing-header::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 60%;
  height: 150%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  position: relative;
  z-index: 1;
}

.intro-section {
  margin: 0 24rpx 32rpx;
}

.intro-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 24rpx;
  padding: 44rpx 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.intro-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(46, 125, 50, 0.08);
  border-radius: 50%;
}

.intro-card::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 140rpx;
  height: 140rpx;
  background: rgba(46, 125, 50, 0.06);
  border-radius: 50%;
}

.intro-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #8B4513, #A0522D);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.3);
  position: relative;
  z-index: 1;
}

.intro-icon {
  font-size: 60rpx;
}

.intro-main-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #5D4037;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.intro-main-desc {
  display: block;
  font-size: 28rpx;
  color: #6D4C41;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.intro-divider {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #8B4513, #A0522D);
  margin: 0 auto 28rpx;
  border-radius: 2rpx;
  position: relative;
  z-index: 1;
}

.intro-text {
  display: block;
  font-size: 28rpx;
  color: #424242;
  line-height: 1.9;
  margin-bottom: 32rpx;
  text-align: justify;
  padding: 0;
  position: relative;
  z-index: 1;
}

.intro-tags {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 0;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}

.tag-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 14rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tag-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #5D4037;
  font-weight: 500;
}

.missing-list {
  margin: 0 24rpx 32rpx;
}

.missing-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
}

.missing-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.missing-time {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: bold;
}

.missing-age {
  font-size: 24rpx;
  color: var(--text-light);
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.missing-body {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
}

.missing-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 24rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  display: flex;
  align-items: center;
  justify-content: center;
}

.missing-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.missing-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.missing-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 12rpx;
}

.missing-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
  flex: 1;
}

.missing-location {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.03), rgba(76, 175, 80, 0.06));
  border-radius: 12rpx;
}

.location-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.location-text {
  font-size: 26rpx;
  color: var(--text-light);
  flex: 1;
}

.missing-contact {
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.08), rgba(76, 175, 80, 0.12));
  border-radius: 12rpx;
  padding: 18rpx;
  text-align: center;
}

.contact-text {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.source-section {
  text-align: center;
  padding: 36rpx 0;
  margin: 0 24rpx;
}

.source-text {
  font-size: 24rpx;
  color: var(--text-light);
}

.footer {
  text-align: center;
  padding: 48rpx 0 24rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 22rpx;
  color: var(--text-light);
  opacity: 0.7;
}

@media (max-width: 375px) {
  .missing-body {
    flex-direction: column;
  }

  .missing-image {
    width: 100%;
    height: 240rpx;
    margin-right: 0;
    margin-bottom: 20rpx;
  }

  .header-title {
    font-size: 42rpx;
  }

  .intro-main-title {
    font-size: 38rpx;
  }
}