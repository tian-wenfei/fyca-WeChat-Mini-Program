<view class="container">
  <!-- 顶部横幅 -->
  <view class="contact-header">
    <text class="header-title">联系我们</text>
    <text class="header-subtitle">期待与您的沟通</text>
  </view>

  <!-- 联系方式 -->
  <view class="section-title">联系方式</view>
  <view class="contact-cards">
    <view class="contact-card" bindtap="copyEmail">
      <view class="card-icon">✉️</view>
      <text class="card-label">电子邮箱</text>
      <text class="card-value">948979226@qq.com</text>
    </view>
    <view class="contact-card" bindtap="makePhoneCall">
      <view class="card-icon">📞</view>
      <text class="card-label">联系电话</text>
      <text class="card-value">+86 15091730188</text>
    </view>
    <view class="contact-card">
      <view class="card-icon">📍</view>
      <text class="card-label">公司地址</text>
      <text class="card-value">陕西省西安市长安区子午大道中段39号</text>
    </view>
  </view>

  <!-- 社交媒体 -->
  <view class="section-title">关注我们</view>
  <view class="social-section">
    <view class="social-item" bindtap="openWechat">
      <view class="social-icon">📱</view>
      <text class="social-name">微信</text>
    </view>
    <view class="social-item" bindtap="openDouyin">
      <view class="social-icon">📺</view>
      <text class="social-name">抖音</text>
    </view>
    <view class="social-item" bindtap="openWebsite">
      <view class="social-icon">🌐</view>
      <text class="social-name">官网</text>
    </view>
    <view class="social-item" bindtap="openWeibo">
      <view class="social-icon">📝</view>
      <text class="social-name">微博</text>
    </view>
  </view>

  <!-- 版权信息 -->
  <view class="footer">
    <text class="footer-text">© 2026 茯忆长安 版权所有</text>
  </view>
</view>
