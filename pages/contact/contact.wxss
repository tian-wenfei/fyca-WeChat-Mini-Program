.container {
  padding-bottom: 40rpx;
}

/* 顶部横幅 */
.contact-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 联系方式卡片 */
.contact-cards {
  margin: 20rpx 0;
}

.contact-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
  text-align: center;
}

.card-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.card-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.card-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.card-action {
  display: block;
  font-size: 24rpx;
  color: var(--primary-color);
  text-decoration: underline;
}

.contact-card {
  transition: all 0.3s ease;
}

.contact-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.15);
}

/* 在线咨询 */
.consult-section {
  margin: 20rpx 0;
}

.consult-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.consult-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.consult-info {
  flex: 1;
}

.consult-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.consult-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.consult-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

/* 表单区域 */
.form-section {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-dark);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-dark);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--text-dark);
  box-sizing: border-box;
}

.textarea-counter {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  border-radius: 40rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 20rpx;
}

.submit-btn::after {
  border: none;
}

/* 地图区域 */
.map-section {
  margin: 20rpx 0;
}

.map-placeholder {
  background: var(--card-bg);
  border-radius: 16rpx;
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.map-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.map-text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 社交媒体 */
.social-section {
  display: flex;
  justify-content: space-around;
  margin: 20rpx 0;
}

.social-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.social-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.social-name {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}
