.container {
  padding-bottom: 60rpx;
}

.contact-header {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 32rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.contact-header::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 60%;
  height: 150%;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 60%);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  position: relative;
  z-index: 1;
}

.contact-cards {
  margin: 0 24rpx 32rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.contact-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.contact-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.card-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.card-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 10rpx;
  font-weight: 500;
}

.card-value {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  word-break: break-all;
}

.card-action {
  display: inline-block;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-top: 8rpx;
}

.consult-section {
  margin: 0 24rpx 32rpx;
}

.consult-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.consult-item:active {
  transform: scale(0.98);
}

.consult-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.consult-info {
  flex: 1;
}

.consult-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.consult-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.consult-arrow {
  font-size: 32rpx;
  color: var(--text-light);
  margin-left: 16rpx;
}

.form-section {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-dark);
  margin-bottom: 14rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.03), rgba(76, 175, 80, 0.06));
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text-dark);
  box-sizing: border-box;
  border: 1rpx solid rgba(46, 125, 50, 0.1);
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: var(--primary-color);
  background: rgba(46, 125, 50, 0.05);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.03), rgba(76, 175, 80, 0.06));
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 28rpx;
  color: var(--text-dark);
  box-sizing: border-box;
  border: 1rpx solid rgba(46, 125, 50, 0.1);
  transition: all 0.3s ease;
}

.form-textarea:focus {
  border-color: var(--primary-color);
  background: rgba(46, 125, 50, 0.05);
}

.textarea-counter {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 10rpx;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  border-radius: 44rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.25);
}

.map-section {
  margin: 0 24rpx 32rpx;
}

.map-placeholder {
  background: linear-gradient(135deg, var(--card-bg) 0%, rgba(129, 199, 132, 0.1) 100%);
  border-radius: 24rpx;
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.map-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.map-text {
  font-size: 28rpx;
  color: var(--text-light);
  font-weight: 500;
}

.social-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin: 0 24rpx;
}

.social-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.social-item:active {
  transform: scale(0.98);
}

.social-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.2);
}

.social-name {
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

.footer {
  text-align: center;
  padding: 48rpx 0 24rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

@media (max-width: 375px) {
  .contact-cards {
    grid-template-columns: 1fr;
  }

  .social-section {
    grid-template-columns: repeat(2, 1fr);
  }

  .header-title {
    font-size: 42rpx;
  }
}