.container {
  padding-bottom: 40rpx;
}

/* ===== Hero Section ===== */
.hero-section {
  position: relative;
  padding: 60rpx 40rpx;
  margin: 24rpx;
  background: linear-gradient(135deg, #1a5c2a 0%, #2d8a4e 40%, #4caf50 100%);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(26, 92, 42, 0.3);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.95);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.15);
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 1rpx;
  font-weight: 500;
}

/* ===== Section ===== */
.section {
  margin: 40rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon-box {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--primary-color);
  letter-spacing: 1rpx;
}

/* ===== Contact List ===== */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.contact-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(46, 125, 50, 0.12);
}

.contact-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
}

.contact-info {
  flex: 1;
  min-width: 0;
}

.contact-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 6rpx;
  font-weight: 600;
}

.contact-value {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-action {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  color: var(--primary-color);
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  border: 1rpx solid rgba(46, 125, 50, 0.15);
}

/* ===== Social Grid ===== */
.social-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.social-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32rpx 20rpx;
  background: var(--card-bg);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.social-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 20rpx rgba(46, 125, 50, 0.12);
}

.social-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.25);
}

.social-name {
  font-size: 26rpx;
  color: var(--text-dark);
  font-weight: 600;
}

/* ===== Responsive ===== */
@media (max-width: 375px) {
  .hero-section {
    padding: 48rpx 28rpx;
    margin: 20rpx;
  }

  .hero-title {
    font-size: 48rpx;
  }

  .social-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .contact-value {
    font-size: 24rpx;
  }
}
