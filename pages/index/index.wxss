.container {
  padding-bottom: 40rpx;
}

.banner {
  height: 400rpx;
  margin: 0 24rpx 32rpx;
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.banner-item {
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  filter: brightness(1.05);
  transition: all 0.5s ease;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(to top,
    rgba(0,0,0,0.8) 0%,
    rgba(0,0,0,0.5) 30%,
    rgba(0,0,0,0.2) 60%,
    transparent 100%);
  border-radius: 24rpx;
}

.banner-content {
  position: absolute;
  bottom: 48rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 1;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.5);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.95);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.4);
  letter-spacing: 1rpx;
}

.quick-entry {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 8rpx;
  background: var(--card-bg);
  border-radius: 20rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
}

.quick-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(46, 125, 50, 0.1);
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.2);
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-dark);
  font-weight: 600;
  text-align: center;
}

.intro-section {
  margin: 0 24rpx 32rpx;
}

.intro-card {
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 10rpx 40rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.intro-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.intro-header {
  text-align: center;
  margin-bottom: 28rpx;
}

.intro-badge-small {
  display: inline-block;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.1), rgba(76, 175, 80, 0.15));
  color: var(--primary-color);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.intro-main-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.intro-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  letter-spacing: 1rpx;
}

.intro-divider {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  margin: 0 auto 28rpx;
  border-radius: 2rpx;
}

.intro-card-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.9;
  text-align: justify;
  margin-bottom: 28rpx;
}

.intro-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
  position: relative;
  overflow: hidden;
}

.intro-cta::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s ease;
}

.intro-cta:active::before {
  left: 100%;
}

.intro-cta:active {
  transform: scale(0.97);
}

.cta-text {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  margin-right: 8rpx;
}

.cta-arrow {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.stats-row {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  margin: 0 24rpx 32rpx;
  padding: 32rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
}

.stat-box {
  flex: 1;
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  font-weight: 500;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, var(--border-color), transparent);
}

.contact-section {
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.contact-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.contact-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.contact-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 14rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
}

.contact-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.03), rgba(76, 175, 80, 0.06));
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  position: relative;
  overflow: hidden;
}

.contact-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3rpx;
  background: linear-gradient(180deg, var(--primary-color), var(--secondary-color));
  opacity: 0;
  transition: opacity 0.3s ease;
}

.contact-item:active {
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.08), rgba(76, 175, 80, 0.12));
  transform: scale(0.98);
}

.contact-item:active::before {
  opacity: 1;
}

.contact-icon-wrap {
  font-size: 36rpx;
  margin-right: 18rpx;
}

.contact-text {
  font-size: 28rpx;
  color: var(--text-light);
  flex: 1;
  line-height: 1.4;
}

.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 22rpx;
  color: var(--text-light);
  opacity: 0.7;
}

@media (max-width: 375px) {
  .quick-entry {
    grid-template-columns: repeat(2, 1fr);
  }

  .banner {
    height: 360rpx;
  }

  .banner-title {
    font-size: 42rpx;
  }

  .stats-row {
    flex-direction: column;
    gap: 24rpx;
  }

  .stat-divider {
    width: 60%;
    height: 1rpx;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  }
}
