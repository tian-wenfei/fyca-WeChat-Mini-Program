.container {
  padding-bottom: 40rpx;
}

.banner {
  height: 420rpx;
  margin: 0 24rpx 24rpx 24rpx;
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.banner::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(46, 125, 50, 0.2), transparent);
}

.banner-item {
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  filter: brightness(1.05);
  transition: all 0.5s ease;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(to top, 
    rgba(0,0,0,0.75) 0%, 
    rgba(0,0,0,0.5) 20%,
    rgba(0,0,0,0.3) 40%, 
    rgba(0,0,0,0.15) 60%,
    transparent 100%);
  backdrop-filter: blur(0);
  border-radius: 24rpx;
}

.banner-content {
  position: absolute;
  bottom: 60rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 1;
}

.banner-title {
  font-size: 52rpx;
  font-weight: bold;
  color: white;
  text-shadow: 2rpx 2rpx 12rpx rgba(0,0,0,0.5), 0 4rpx 8rpx rgba(0,0,0,0.3);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.95);
  text-shadow: 1rpx 1rpx 4rpx rgba(0,0,0,0.4);
  letter-spacing: 1rpx;
}

.quick-entry {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 30rpx 24rpx;
  margin: 24rpx;
  background: var(--card-bg);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.04), rgba(76, 175, 80, 0.08));
}

.quick-item:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.08), rgba(76, 175, 80, 0.12));
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-dark);
  font-weight: 600;
  text-align: center;
}

.intro-hero {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.intro-hero::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 80%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
}

.intro-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  color: white;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.intro-main-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  letter-spacing: 8rpx;
  position: relative;
  z-index: 1;
}

.intro-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.intro-divider {
  width: 80rpx;
  height: 4rpx;
  background: rgba(255,255,255,0.8);
  margin: 0 auto;
  border-radius: 2rpx;
  position: relative;
  z-index: 1;
}

.intro-section {
  margin: 0 24rpx 32rpx;
}

.intro-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
}

.intro-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  border-radius: 20rpx 20rpx 0 0;
}

.intro-card-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 2;
  text-align: justify;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin: 32rpx 24rpx 20rpx;
  display: flex;
  align-items: center;
}

.pain-point-list {
  margin: 0 24rpx 32rpx;
}

.pain-item {
  display: flex;
  align-items: flex-start;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.pain-item:active {
  transform: scale(0.98);
}

.pain-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.pain-content {
  flex: 1;
}

.pain-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 8rpx;
}

.pain-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
}

.tech-solution-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.tech-badge {
  display: inline-block;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.2);
}

.tech-product-image {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.05), rgba(76, 175, 80, 0.1));
}

.product-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tech-features {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.tech-feature {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.04), rgba(76, 175, 80, 0.08));
  border-radius: 16rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.06);
}

.tech-feature-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tech-feature-info {
  flex: 1;
}

.tech-feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 4rpx;
}

.tech-feature-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
}

.advantage-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 0 24rpx 32rpx;
}

.advantage-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.advantage-item:active {
  transform: scale(0.98);
}

.advantage-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.advantage-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  font-weight: 500;
}

.business-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 36rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.business-header {
  text-align: center;
  margin-bottom: 28rpx;
}

.business-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.business-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.business-model {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
  gap: 8rpx;
}

.model-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.08), rgba(76, 175, 80, 0.12));
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  min-width: 120rpx;
}

.model-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.model-text {
  font-size: 22rpx;
  color: var(--text-dark);
  font-weight: 600;
}

.model-arrow {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: bold;
  padding: 0 4rpx;
}

.business-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.7;
  text-align: center;
}

.team-strength-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.strength-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(46, 125, 50, 0.08);
}

.strength-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.strength-item:first-child {
  padding-top: 0;
}

.strength-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.strength-content {
  flex: 1;
}

.strength-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.strength-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
}

.result-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.result-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(46, 125, 50, 0.08);
}

.result-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.result-item:first-child {
  padding-top: 0;
}

.result-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
}

.result-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 6rpx;
}

.result-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}

.market-card {
  background: linear-gradient(135deg, #1B5E20, #2E7D32);
  border-radius: 20rpx;
  padding: 36rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.2);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.market-item {
  text-align: center;
}

.market-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.market-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.strategy-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.strategy-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(46, 125, 50, 0.08);
}

.strategy-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.strategy-item:first-child {
  padding-top: 0;
}

.strategy-phase {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: white;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.strategy-content {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.5;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 0 24rpx 32rpx;
}

.benefit-item {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s ease;
}

.benefit-item:active {
  transform: scale(0.98);
}

.benefit-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.benefit-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.benefit-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.4;
}

.stats-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 24rpx 24rpx;
}

.stat-item {
  background: linear-gradient(135deg, var(--card-bg) 0%, rgba(129, 199, 132, 0.12) 100%);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.stat-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
}

.stat-number {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.stat-number-with-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.arrow-up {
  color: #FF5252;
  font-size: 24rpx;
  font-weight: 900;
  margin-left: 6rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

.value-section {
  margin: 0 24rpx 24rpx;
}

.welfare-card {
  background: linear-gradient(135deg, #2E7D32, #388E3C);
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 32rpx rgba(46, 125, 50, 0.25);
  position: relative;
  overflow: hidden;
}

.welfare-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
}

.welfare-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 20rpx;
}

.welfare-content {
  position: relative;
  z-index: 1;
}

.welfare-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
}

.welfare-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.welfare-highlight {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
  font-weight: 600;
}

.contact-section {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.contact-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.contact-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.contact-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.03), rgba(76, 175, 80, 0.06));
  border: 1rpx solid rgba(46, 125, 50, 0.06);
}

.contact-item:active {
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.08), rgba(76, 175, 80, 0.12));
  transform: scale(0.98);
}

.contact-icon-wrap {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.contact-text {
  font-size: 26rpx;
  color: var(--text-light);
  flex: 1;
}

.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 22rpx;
  color: var(--text-light);
  opacity: 0.7;
}

@media (max-width: 375px) {
  .quick-entry {
    grid-template-columns: repeat(2, 1fr);
  }

  .tech-features {
    grid-template-columns: 1fr;
  }

  .advantage-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .benefit-grid {
    grid-template-columns: 1fr;
  }

  .market-card {
    grid-template-columns: 1fr;
    gap: 24rpx;
  }

  .stats-container {
    grid-template-columns: repeat(2, 1fr);
  }

  .banner {
    height: 360rpx;
  }

  .business-model {
    flex-direction: column;
  }

  .model-arrow {
    transform: rotate(90deg);
  }

  .strategy-item {
    flex-direction: column;
    align-items: flex-start;
  }

  .strategy-phase {
    margin-bottom: 12rpx;
  }
}