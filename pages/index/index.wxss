.container {
  padding-bottom: 40rpx;
}

/* 轮播图 */
.banner {
  height: 400rpx;
  margin: 0 -20rpx;
}

.banner-item {
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  text-shadow: 2rpx 2rpx 8rpx rgba(0,0,0,0.3);
}

.banner-subtitle {
  font-size: 32rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 20rpx;
}

/* 快捷入口 */
.quick-entry {
  display: flex;
  justify-content: space-around;
  background: var(--card-bg);
  padding: 30rpx 20rpx;
  margin: 20rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.2);
}

.quick-text {
  font-size: 26rpx;
  color: var(--text-dark);
  font-weight: 500;
}

/* 企业简介卡片 */
.intro-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.intro-content {
  margin-bottom: 20rpx;
}

.intro-text {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.8;
  text-align: justify;
}

.intro-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 核心产品 */
.core-product {
  display: flex;
  flex-direction: column;
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.core-product-image {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.core-product-image .product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.core-product-info {
  flex: 1;
}

.core-product-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  text-align: center;
}

.core-product-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-dark);
  margin-bottom: 20rpx;
  text-align: center;
  position: relative;
}

.core-product-subtitle::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

.core-product-desc {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.6;
  margin-bottom: 24rpx;
  text-align: justify;
}

.core-product-features {
  margin-bottom: 24rpx;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.feature-check {
  color: var(--primary-color);
  font-weight: bold;
  margin-right: 12rpx;
  font-size: 28rpx;
  line-height: 1.4;
}

.feature-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.4;
}

.core-product-btn {
  background: var(--primary-color);
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  margin-top: 8rpx;
}

.core-product-btn::after {
  border: none;
}

/* 数据统计 */
.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin: 20rpx 0;
}

.stat-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.stat-number {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-number-with-arrow {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  margin-bottom: 8rpx;
  position: relative;
}

.arrow-up {
  color: #FF5252;
  font-size: 20rpx;
  font-weight: 900;
  margin-left: 4rpx;
  line-height: 1;
}

.stat-number-with-arrow .stat-number {
  margin-bottom: 0;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
}

/* 公益寻人卡片 */
.welfare-card {
  background: linear-gradient(135deg, #2E7D32, #388E3C);
  border-radius: 16rpx;
  padding: 40rpx;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
}

.welfare-content {
  text-align: center;
}

.welfare-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.welfare-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.welfare-btn {
  background: white;
  color: var(--primary-color);
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.welfare-btn::after {
  border: none;
}

/* 联系我们 */
.contact-section {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 30rpx 0 20rpx;
  text-align: center;
}

.contact-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 24rpx;
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.contact-item:active {
  background: rgba(46, 125, 50, 0.05);
  transform: scale(0.98);
}

.contact-icon {
  font-size: 32rpx;
}

.contact-text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-light);
}
