<view class="container">
  <swiper class="banner" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" duration="500" circular="{{true}}">
    <swiper-item>
      <view class="banner-item">
        <image class="banner-image" src="/images/one.jpg" mode="aspectFill" />
        <view class="banner-overlay"></view>
        <view class="banner-content">
          <text class="banner-title">科技赋能</text>
          <text class="banner-subtitle">富硒茯茶智能化发花技术</text>
        </view>
      </view>
    </swiper-item>
    <swiper-item>
      <view class="banner-item">
        <image class="banner-image" src="/images/two.jpg" mode="aspectFill" />
        <view class="banner-overlay"></view>
        <view class="banner-content">
          <text class="banner-title">助农增收</text>
          <text class="banner-subtitle">智能装备+标准工艺+数字平台</text>
        </view>
      </view>
    </swiper-item>
    <swiper-item>
      <view class="banner-item">
        <image class="banner-image" src="/images/three.jpg" mode="aspectFill" />
        <view class="banner-overlay"></view>
        <view class="banner-content">
          <text class="banner-title">乡村振新</text>
          <text class="banner-subtitle">推动陕南安康富硒茯茶产业升级</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="quick-entry">
    <view class="quick-item" bindtap="goToPage" data-page="/pages/about/about">
      <view class="quick-icon">🏛️</view>
      <text class="quick-text">项目简介</text>
    </view>
    <view class="quick-item" bindtap="goToPage" data-page="/pages/technology/technology">
      <view class="quick-icon">🔬</view>
      <text class="quick-text">产品技术</text>
    </view>
    <view class="quick-item" bindtap="goToPage" data-page="/pages/value/value">
      <view class="quick-icon">💎</view>
      <text class="quick-text">核心价值</text>
    </view>
    <view class="quick-item" bindtap="goToPage" data-page="/pages/team/team">
      <view class="quick-icon">💬</view>
      <text class="quick-text">联系我们</text>
    </view>
  </view>

  <view class="intro-section">
    <view class="intro-card">
      <view class="intro-header">
        <view class="intro-badge-small">🌱 乡村振兴 · 科技助农</view>
        <text class="intro-main-title">茯兴硒乡</text>
        <text class="intro-subtitle">富硒茯茶金花智控设备助农增收新引擎</text>
      </view>
      <view class="intro-divider"></view>
      <text class="intro-card-text">项目紧扣农业农村现代化战略，聚焦陕南安康富硒茯茶产业痛点，以智能化发花技术为核心，研发金花智控设备，打造"智能装备+标准工艺+数字平台+品牌赋能"一体化方案，破解产业瓶颈，赋能茶农增收与区域特色经济高质量发展。</text>
      <view class="intro-cta" bindtap="goToPage" data-page="/pages/about/about">
        <text class="cta-text">了解更多</text>
        <text class="cta-arrow">→</text>
      </view>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-box">
      <text class="stat-number">98.6%</text>
      <text class="stat-label">发花成功率</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-box">
      <text class="stat-number">↑32%</text>
      <text class="stat-label">硒含量提升</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-box">
      <text class="stat-number">1.27万</text>
      <text class="stat-label">户均年增收</text>
    </view>
  </view>

  <view class="contact-section">
    <view class="contact-header">
      <view class="contact-icon">💬</view>
      <text class="contact-title">联系我们</text>
    </view>
    <view class="contact-info">
      <view class="contact-item" bindtap="makePhoneCall">
        <text class="contact-icon-wrap">📞</text>
        <text class="contact-text">+86 15091730188</text>
      </view>
      <view class="contact-item" bindtap="copyEmail">
        <text class="contact-icon-wrap">✉️</text>
        <text class="contact-text">948979226@qq.com</text>
      </view>
      <view class="contact-item">
        <text class="contact-icon-wrap">📍</text>
        <text class="contact-text">陕西省渭南市临渭区向阳路街道办事处文昌阁社区</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">© 2026 茯忆长安 版权所有</text>
    <text class="footer-icp">陕ICP备2026007411号</text>
  </view>
</view>
