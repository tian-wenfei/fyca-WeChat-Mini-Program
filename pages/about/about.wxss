.container {
  padding-bottom: 40rpx;
}

/* 顶部大图 */
.about-header {
  height: 300rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  margin: -20rpx -20rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-content {
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 企业介绍卡片 */
.about-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.about-text {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 2;
  text-align: justify;
  white-space: pre-line;
}

/* 时间轴 */
.timeline {
  position: relative;
  padding-left: 40rpx;
  margin: 20rpx 0;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: var(--border-color);
}

.timeline-item {
  position: relative;
  padding: 20rpx 0 30rpx 30rpx;
}

.timeline-dot {
  position: absolute;
  left: -32rpx;
  top: 30rpx;
  width: 20rpx;
  height: 20rpx;
  background: var(--primary-color);
  border-radius: 50%;
  border: 4rpx solid var(--card-bg);
}

.timeline-content {
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.timeline-year {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.timeline-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 8rpx;
}

.timeline-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
}

/* 企业文化网格 */
.culture-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 20rpx 0;
}

.culture-item {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.culture-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.culture-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.culture-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.5;
}

/* 生产基地 */
.base-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.base-info {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.base-item {
  text-align: center;
}

.base-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.base-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.base-desc {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.8;
  text-align: justify;
}

/* 荣誉资质 */
.honor-list {
  margin: 20rpx 0;
}

.honor-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.1);
}

.honor-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.honor-text {
  font-size: 28rpx;
  color: var(--text-dark);
  font-weight: 500;
}
