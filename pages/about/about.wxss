/* container */
.container {
  padding-bottom: 60rpx;
}

/* ===== Hero Section ===== */
.hero-section {
  position: relative;
  padding: 60rpx 40rpx;
  margin: 24rpx;
  background: linear-gradient(135deg, #1a5c2a 0%, #2d8a4e 40%, #4caf50 100%);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(26, 92, 42, 0.3);
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.95);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255,255,255,0.15);
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.2);
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.8;
  text-align: justify;
  letter-spacing: 0.5rpx;
}

/* ===== Section ===== */
.section {
  margin: 40rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon-box {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.25);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--primary-color);
  letter-spacing: 1rpx;
}

/* ===== Background Card ===== */
.background-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.background-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, var(--primary-color), var(--secondary-color));
}

.background-text {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.8;
  text-align: justify;
}

/* ===== Pain Points Grid ===== */
.pain-points-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.pain-point {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.pain-point:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(46, 125, 50, 0.1);
}

.pain-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.pain-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 10rpx;
}

.pain-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.6;
}

/* ===== Tech Card ===== */
.tech-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.tech-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.tech-header {
  text-align: center;
  margin-bottom: 28rpx;
}

.tech-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.tech-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

.tech-features {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.tech-feature {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.05), rgba(76, 175, 80, 0.1));
  border-radius: 16rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.08);
}

.feature-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.feature-text {
  font-size: 24rpx;
  color: var(--text-dark);
  font-weight: 600;
}

.tech-image-wrap {
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.05), rgba(76, 175, 80, 0.08));
}

.tech-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
}

/* ===== Advantages List ===== */
.advantages-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.advantage-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: 18rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(46, 125, 50, 0.06);
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.advantage-item:active {
  transform: translateX(6rpx);
  box-shadow: 0 4rpx 24rpx rgba(46, 125, 50, 0.12);
}

.advantage-number {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #ffffff;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.25);
}

.advantage-content {
  flex: 1;
}

.advantage-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 6rpx;
}

.advantage-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
}

/* ===== Business Card ===== */
.business-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(46, 125, 50, 0.08);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  overflow: hidden;
}

.business-image {
  width: 100%;
  display: block;
}

/* ===== Team Card ===== */
.team-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.team-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.team-intro {
  text-align: center;
  margin-bottom: 28rpx;
}

.team-intro-text {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.7;
}

.team-image-wrap {
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.05), rgba(76, 175, 80, 0.08));
}

.team-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
}

.team-achievements {
  display: flex;
  justify-content: space-around;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(46, 125, 50, 0.08);
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.achievement-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.achievement-text {
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 500;
}

/* ===== Results Card ===== */
.results-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.results-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.result-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 28rpx;
}

.result-stat {
  text-align: center;
}

.result-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  font-weight: 500;
}

.result-map {
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.05), rgba(76, 175, 80, 0.08));
}

.map-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
}

/* ===== Value Card ===== */
.value-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 125, 50, 0.1);
  border: 1rpx solid rgba(46, 125, 50, 0.08);
  position: relative;
  overflow: hidden;
}

.value-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
}

.value-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.value-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 28rpx 20rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.04), rgba(76, 175, 80, 0.08));
  border-radius: 18rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.value-item:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 20rpx rgba(46, 125, 50, 0.12);
}

.value-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, rgba(46, 125, 50, 0.12), rgba(76, 175, 80, 0.18));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 14rpx;
}

.value-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
  margin-bottom: 10rpx;
}

.value-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.6;
}

/* ===== Responsive ===== */
@media (max-width: 375px) {
  .hero-section {
    padding: 48rpx 28rpx;
    margin: 20rpx;
  }

  .hero-title {
    font-size: 48rpx;
  }

  .pain-points-grid {
    grid-template-columns: 1fr;
  }

  .tech-features {
    grid-template-columns: 1fr;
  }

  .result-stats {
    flex-direction: column;
    gap: 20rpx;
  }

  .team-achievements {
    flex-direction: column;
    gap: 20rpx;
  }
}
